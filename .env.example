# Public site URL (used for canonical URLs, hreflang, sitemap)
NEXT_PUBLIC_SITE_URL=https://tibyanstrategy.com

# Set to "staging" on the Railway staging environment to emit noindex robots
NEXT_PUBLIC_ENVIRONMENT=production

# Railway Postgres — when unset, leads are logged to console (dev mode)
DATABASE_URL=

# Optional webhook notified on every lead (point at HubSpot/Zapier/Make)
LEADS_WEBHOOK_URL=

# Cloudflare Turnstile — forms work without it until keys exist
TURNSTILE_SECRET_KEY=

# Resend — newsletter double opt-in + confirmation emails.
# Without these, subscriptions are recorded but no email is sent.
RESEND_API_KEY=
RESEND_FROM="Tibyan <news@tibyanstrategy.com>"

# Google Search Console "HTML tag" verification token (alternative to DNS)
GOOGLE_SITE_VERIFICATION=

# Booking URL for /book-a-call. Defaults to the Google Calendar appointment
# schedule baked into lib/i18n.ts. A Google "Website embed" URL
# (calendar.google.com/calendar/appointments/...?gv=true) or a Cal.com/Calendly
# URL renders inline; any other link (e.g. calendar.app.google short link)
# renders as a button that opens in a new tab.
NEXT_PUBLIC_BOOKING_URL=

# WhatsApp number in international format, e.g. 9665XXXXXXXX (button hidden when unset)
NEXT_PUBLIC_WHATSAPP_NUMBER=
